[server]
bind = "127.0.0.1:3000"
metrics_bind = "127.0.0.1:9090"
trusted_proxies = []

[dns]
# Resolvers: predefined names ("cloudflare", "google", "quad9", "system") or
# explicit IPv4 addresses ("1.1.1.1", "8.8.8.8") or "ip:port" ("1.1.1.1:53").
# Predefined names are expanded to IPv4-only UDP configs automatically.
# Multiple entries are queried round-robin.
resolvers = ["cloudflare"]
timeout_ms = 5000

[dnsbl]
zones = [
  "zen.spamhaus.org",
  "b.barracudacentral.org",
  "bl.spamcop.net",
  "dbl.spamhaus.org",
]
timeout_ms = 2000
# DNSBL queries use a separate resolver. Spamhaus and most public DNSBLs block
# queries from public/open resolvers (Cloudflare, Google, Quad9) and return
# synthetic 127.255.255.x responses. Default to "system" (host resolv.conf);
# point at a local resolver ["127.0.0.1:53"] for best results.
resolvers = ["system"]

[http]
timeout_ms = 10000

[rate_limit]
per_ip = "10/min"

[dkim]
max_user_selectors = 5

# [enrichment]
# ip_url = "https://ip.netray.info"
# timeout_ms = 5000

[telemetry]
log_format = "json"
service_name = "beacon"
sample_rate = 1.0
# otlp_endpoint = "http://localhost:4317"
